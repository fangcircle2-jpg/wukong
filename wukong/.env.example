# ============================================
# 悟空 Wukong — 环境变量配置模板
# ============================================
# 使用方法：复制本文件为 .env，填入你的配置
#   cp .env.example .env
# 注意：.env 文件已列入 .gitignore，请勿提交到版本控制！

# ============================================
# LLM Provider 选择
# ============================================
# 可选值: openai | anthropic | google | local
WUKONG_LLM_PROVIDER=anthropic

# 默认模型名称（与 provider 对应）
WUKONG_LLM_MODEL=claude-sonnet-4-20250514

# ============================================
# API Keys（填入你使用的 provider 对应密钥）
# ============================================

# Anthropic (Claude 系列)
WUKONG_LLM_ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# OpenAI (GPT 系列)
WUKONG_LLM_OPENAI_API_KEY=sk-your-openai-api-key-here

# Google AI (Gemini 系列)
WUKONG_LLM_GOOGLE_API_KEY=your-google-api-key-here

# ============================================
# OpenAI 兼容接口（可选）
# ============================================
# 如需使用智谱 GLM、Moonshot、DeepSeek 等 OpenAI 兼容 API，
# 将 provider 设为 openai，并配置以下两项：
#
# 智谱 AI 示例:
#   WUKONG_LLM_PROVIDER=openai
#   WUKONG_LLM_MODEL=glm-4-plus
#   WUKONG_LLM_OPENAI_API_KEY=your-zhipu-api-key-here
#   WUKONG_LLM_OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
#
# Moonshot 示例:
#   WUKONG_LLM_OPENAI_BASE_URL=https://api.moonshot.cn/v1
#
# DeepSeek 示例:
#   WUKONG_LLM_OPENAI_BASE_URL=https://api.deepseek.com/v1

# WUKONG_LLM_OPENAI_BASE_URL=

# ============================================
# 本地模型配置（Ollama 等，可选）
# ============================================
# WUKONG_LLM_LOCAL_BASE_URL=http://localhost:11434/v1
# WUKONG_LLM_LOCAL_MODEL=llama3.2

# ============================================
# 应用配置
# ============================================
# 日志级别: DEBUG | INFO | WARNING | ERROR
WUKONG_LOG_LEVEL=INFO

# 启用流式输出
WUKONG_STREAMING=true

# 最大上下文 token 数
WUKONG_MAX_CONTEXT_TOKENS=128000

# ============================================
# 权限控制
# ============================================
# 自动确认只读操作（安全）
WUKONG_PERMISSION_AUTO_CONFIRM_SAFE=true

# 自动确认文件写入操作（谨慎）
WUKONG_PERMISSION_AUTO_CONFIRM_MODERATE=false

# 自动确认代码执行等危险操作（不建议开启）
WUKONG_PERMISSION_AUTO_CONFIRM_DANGEROUS=false

# ============================================
# MCP 协议配置（可选）
# ============================================
# 启用 MCP 服务器支持
WUKONG_MCP_ENABLED=true

# 自定义 MCP 配置文件路径（默认 ~/.config/wukong/mcp_servers.json）
# WUKONG_MCP_CONFIG_FILE=~/.config/wukong/mcp_servers.json
